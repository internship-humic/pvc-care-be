// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [postgis]
}

model Farmer {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  password     String
  address      String?
  phone_number String?
  image_url    String?
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  farms Farm[]

  @@map("farmers")
}

model Customer {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  password     String
  address      String?
  phone_number String?
  image_url    String?
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  @@map("customers")
}

model Admin {
  id         String   @id @default(uuid())
  email      String   @unique
  password   String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("admins")
}

model Farm {
  id          String                                @id @default(uuid())
  farmer_id   String
  name        String
  description String
  pinpoints   Unsupported("geography(Point, 4326)")
  address     String
  created_at  DateTime                              @default(now())
  updated_at  DateTime                              @updatedAt

  farmer        Farmer        @relation(fields: [farmer_id], references: [id])
  farm_products FarmProduct[]

  @@map("farms")
}

model Plant {
  id         String   @id @default(uuid())
  name       String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  farm_products FarmProduct[]

  @@map("plants")
}

model FarmProduct {
  id         String   @id @default(uuid())
  farm_id    String
  plant_id   String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  farm      Farm        @relation(fields: [farm_id], references: [id], onDelete: Cascade)
  plant     Plant       @relation(fields: [plant_id], references: [id])
  harvested Harvested[]
  planted   Planted[]
  sale      Sale[]

  @@map("farm_products")
}

model Harvested {
  id              String   @id @default(uuid())
  farm_product_id String
  quantity        Float    @default(0)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  farm_product FarmProduct @relation(fields: [farm_product_id], references: [id], onDelete: Cascade)

  @@map("harvested")
}

model Planted {
  id              String   @id @default(uuid())
  farm_product_id String
  quantity        Float    @default(0)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  farm_product FarmProduct @relation(fields: [farm_product_id], references: [id], onDelete: Cascade)

  @@map("planted")
}

model Sale {
  id              String   @id @default(uuid())
  farm_product_id String
  quantity        Float    @default(0)
  price           Float    @default(0)
  status          Boolean  @default(false)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  farm_product FarmProduct @relation(fields: [farm_product_id], references: [id], onDelete: Cascade)

  @@map("sales")
}
